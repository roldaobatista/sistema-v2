# Template para DESENVOLVIMENTO LOCAL.
APP_NAME=Kalibrium
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Frontend ───
FRONTEND_URL=http://SEU-IP-OU-DOMINIO
PUBLIC_FRONTEND_URL=
PUBLIC_APP_URL=

# ─── Sanctum (Tokens API) ───
# Expiração de tokens em minutos (10080 = 7 dias, null = sem expiração)
SANCTUM_TOKEN_EXPIRATION=10080
# Token em cookie httpOnly (true = mais seguro; frontend deve ter VITE_SANCTUM_USE_COOKIE=true e mesma origem)
SANCTUM_USE_TOKEN_COOKIE=false
SANCTUM_AUTH_COOKIE_NAME=auth_token

# --- Sentry (Error Tracking) ---
SENTRY_LARAVEL_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=local
SENTRY_ENABLE_LOGS=true
SENTRY_LOG_LEVEL=warning
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=1.0.0

# --- Laravel Telescope / Boost / MCP ---
TELESCOPE_ENABLED=false
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
BOOST_ENABLED=true
BOOST_BROWSER_LOGS_WATCHER=true
BOOST_PHP_EXECUTABLE_PATH=php
BOOST_COMPOSER_EXECUTABLE_PATH=composer
BOOST_NPM_EXECUTABLE_PATH=npm

# --- OpenTelemetry (usar com docker-compose.observability.yml ou collector externo) ---
OTEL_SERVICE_NAME=kalibrium-backend
OTEL_RESOURCE_ATTRIBUTES=service.namespace=kalibrium,deployment.environment=production
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_PHP_AUTOLOAD_ENABLED=true
OTEL_PHP_DISABLED_INSTRUMENTATIONS=
# Windows local sem ext-opentelemetry: use true para desabilitar o SDK atÃ© rodar em Docker/Linux.
OTEL_SDK_DISABLED=false

LOG_CHANNEL=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database ───
# Docker: use "mysql" como host (nome do serviço no docker-compose)
# Externo: use o IP/hostname do servidor MySQL
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kalibrium
DB_USERNAME=kalibrium
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# Redis é recomendado para produção (mais rápido que database)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ─── Redis ───
# Docker: use "redis" como host (nome do serviço no docker-compose)
# ⚠️  CRÍTICO: REDIS_PASSWORD DEVE SER IGUAL ao valor no .env raiz do projeto!
#     O compose usa: --requirepass "${REDIS_PASSWORD}" (sem default — obrigatório definir)
#     Se REDIS_PASSWORD estiver vazio/null e o compose esperar senha → ERRO 500 em TUDO
#     Se REDIS_PASSWORD tiver valor e o compose NÃO esperar senha → ERRO 500 em TUDO
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=ALTERE_ESTA_SENHA
REDIS_PORT=6379
REDIS_CACHE_DB=1

# ─── CORS (OBRIGATÓRIO em produção!) ───
# ⚠️  ATENÇÃO: Sem configurar isso, o frontend NÃO consegue se comunicar com a API!
# Coloque aqui o(s) domínio(s) do frontend (sem barra no final)
# Para múltiplos domínios, separe por vírgula: https://app.seudominio.com,https://portal.seudominio.com
# Para acesso por IP (deploy inicial): http://SEU-IP-OU-DOMINIO
# O deploy.sh irá BLOQUEAR o deploy se este valor não for alterado!
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ─── Email (transacional) ───
# Recomendação: Brevo (ex-Sendinblue) plano gratuito para até 300 emails/dia
# Titan/HostGator SMTP funciona mas pode ter limites de envio
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.titan.email
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=sistema@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS S3 (opcional — para armazenar arquivos na nuvem) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Alertas (email para falhas críticas: scheduler, Horizon) ---
SYSTEM_ALERT_EMAIL=admin@example.com

# ─── Laravel Reverb (WebSocket para chat em tempo real) ───
# Gere com: php -r "echo bin2hex(random_bytes(20));"
REVERB_APP_ID=kalibrium
REVERB_APP_KEY=sua-reverb-app-key
REVERB_APP_SECRET=sua-reverb-app-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https
# Origens permitidas para WebSocket (separar por vírgula; em produção não use *)
REVERB_ALLOWED_ORIGINS=http://SEU-IP-OU-DOMINIO

# ─── Frontend (variáveis injetadas no build do Vite) ───
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${APP_URL}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Integração Fiscal NF-e/NFS-e (Nuvem Fiscal — opcional) ───
# Crie sua conta em https://nuvemfiscal.com.br
# Documentação da API: https://dev.nuvemfiscal.com.br/docs
NUVEMFISCAL_URL=https://api.nuvemfiscal.com.br
NUVEMFISCAL_CLIENT_ID=
NUVEMFISCAL_CLIENT_SECRET=

# ─── Push Notifications (VAPID Web Push — opcional) ───
# Gere as chaves com: npx web-push generate-vapid-keys
# Ou use: php -r "echo sodium_bin2base64(sodium_crypto_sign_publickey(sodium_crypto_sign_keypair()), 7);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ─── Evolution API (WhatsApp — opcional) ───
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=default

# ─── Integração Auvo (importação/exportação de dados) ───
# Chaves disponíveis em: app.auvo.com.br/integracao (API Auvo)
AUVO_API_KEY=
AUVO_API_TOKEN=
# Opcional: em ambientes onde cURL falha com "SSL certificate problem: unable to get local issuer certificate"
# (comum no Windows/XAMPP), defina o caminho para o arquivo CA bundle. Ex.: C:\projetos\sistema\backend\cacert.pem
# Baixe em: https://curl.se/ca/cacert.pem
# AUVO_SSL_CAFILE=
# Apenas desenvolvimento local: AUVO_SSL_VERIFY=false desativa verificação SSL (cURL 60).
# Em produção este valor é IGNORADO (a verificação SSL sempre permanece ativa). Não adicione em .env de produção.
# AUVO_SSL_VERIFY=false

# ─── Fiscal — provedor ativo e Focus NF-e ───
# Provedor fiscal ativo: focusnfe | nuvemfiscal (padrão: focusnfe)
FISCAL_PROVIDER=focusnfe
# Token de autenticação do Focus NF-e (https://focusnfe.com.br → Painel → API Tokens)
FOCUSNFE_TOKEN=
# Ambiente: homologation (testes) | production (notas reais)
FOCUSNFE_ENV=homologation
# Secret para validar webhooks recebidos do FocusNFe
FISCAL_WEBHOOK_SECRET=
# Natureza da operação padrão (NFS-e)
FISCAL_NATUREZA_OPERACAO="Prestacao de Servicos"
# Regime tributário: 1=Simples Nacional, 2=Simples Nacional Excesso, 3=Regime Normal
FISCAL_REGIME_TRIBUTARIO=1

# ─── Integração Fiscal Externa (opcional — API de emissão NF-e/NFS-e alternativa) ───
# FISCAL_EXTERNAL_BASE_URL=https://api.exemplo.com.br
# FISCAL_EXTERNAL_TOKEN=

# ─── Webhook Secret (obrigatório em produção) ───
# WEBHOOK_SECRET=seu-segredo-webhook-aqui

# ─── SMS para Cobrança (opcional — padrão: log) ───
# Driver: log (apenas grava log) | twilio (envia SMS real)
COLLECTION_SMS_DRIVER=log
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── PSP / Gateway de Pagamento (Boleto & PIX) ───
# Provedor: asaas (padrão)
PAYMENT_PROVIDER=asaas
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
# Circuit breaker (opcional)
# ASAAS_CB_THRESHOLD=5
# ASAAS_CB_TIMEOUT=120

# ─── Docker Compose (usado pelo docker-compose.prod.yml) ───
DB_ROOT_PASSWORD=

# ─── Go2RTC (gateway câmeras RTSP → WebRTC) ───
GO2RTC_API_ORIGIN=https://your-domain.com

# ─── Variáveis de Compose (copiadas para .env na raiz do projeto) ───
# VITE_APP_URL=https://your-domain.com
# VITE_API_URL=https://your-domain.com/api/v1
