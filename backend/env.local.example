# Copie para .env (ou mescle estas linhas no seu .env) para rodar LOCAL sem MySQL/Redis.
# Uso: no diretorio backend, ajuste seu .env com os valores abaixo.

APP_ENV=local
APP_DEBUG=true

# Banco: SQLite (nao precisa de MySQL)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Sessao e cache em arquivo (nao precisa de Redis)
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Observabilidade local
TELESCOPE_ENABLED=true
BOOST_ENABLED=true
INSTALL_DEV_DEPENDENCIES=true
OTEL_SDK_DISABLED=true
OTEL_TRACES_EXPORTER=otlp
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_PHP_AUTOLOAD_ENABLED=true
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=local-dev
