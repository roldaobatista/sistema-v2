FROM node:22-alpine AS build

ARG VITE_APP_URL
ARG VITE_API_URL
ARG VITE_REVERB_APP_KEY
ARG VITE_REVERB_HOST
ARG VITE_REVERB_PORT=443
ARG VITE_REVERB_SCHEME=https
ARG VITE_GO2RTC_URL
ARG VITE_ERROR_REPORTING_URL
ARG VITE_SENTRY_ENABLED=true
ARG VITE_SENTRY_DSN
ARG VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
ARG VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
ARG VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
ARG VITE_SENTRY_RELEASE
ARG VITE_APP_ENV=production
ARG VITE_ENABLE_QUERY_DEVTOOLS=false
ARG SENTRY_AUTH_TOKEN
ARG SENTRY_ORG
ARG SENTRY_PROJECT
ARG SENTRY_URL=https://sentry.io/

ENV VITE_APP_URL=$VITE_APP_URL
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_REVERB_APP_KEY=$VITE_REVERB_APP_KEY
ENV VITE_REVERB_HOST=$VITE_REVERB_HOST
ENV VITE_REVERB_PORT=$VITE_REVERB_PORT
ENV VITE_REVERB_SCHEME=$VITE_REVERB_SCHEME
ENV VITE_GO2RTC_URL=$VITE_GO2RTC_URL
ENV VITE_ERROR_REPORTING_URL=$VITE_ERROR_REPORTING_URL
ENV VITE_SENTRY_ENABLED=$VITE_SENTRY_ENABLED
ENV VITE_SENTRY_DSN=$VITE_SENTRY_DSN
ENV VITE_SENTRY_TRACES_SAMPLE_RATE=$VITE_SENTRY_TRACES_SAMPLE_RATE
ENV VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=$VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE
ENV VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=$VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE
ENV VITE_SENTRY_RELEASE=$VITE_SENTRY_RELEASE
ENV VITE_APP_ENV=$VITE_APP_ENV
ENV VITE_ENABLE_QUERY_DEVTOOLS=$VITE_ENABLE_QUERY_DEVTOOLS
ENV SENTRY_AUTH_TOKEN=$SENTRY_AUTH_TOKEN
ENV SENTRY_ORG=$SENTRY_ORG
ENV SENTRY_PROJECT=$SENTRY_PROJECT
ENV SENTRY_URL=$SENTRY_URL

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps

COPY . .

RUN printf "VITE_APP_URL=%s\nVITE_API_URL=%s\nVITE_REVERB_APP_KEY=%s\nVITE_REVERB_HOST=%s\nVITE_REVERB_PORT=%s\nVITE_REVERB_SCHEME=%s\nVITE_GO2RTC_URL=%s\nVITE_ERROR_REPORTING_URL=%s\nVITE_SENTRY_ENABLED=%s\nVITE_SENTRY_DSN=%s\nVITE_SENTRY_TRACES_SAMPLE_RATE=%s\nVITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=%s\nVITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=%s\nVITE_SENTRY_RELEASE=%s\nVITE_APP_ENV=%s\nVITE_ENABLE_QUERY_DEVTOOLS=%s\nSENTRY_AUTH_TOKEN=%s\nSENTRY_ORG=%s\nSENTRY_PROJECT=%s\nSENTRY_URL=%s\n" \
    "$VITE_APP_URL" "$VITE_API_URL" "$VITE_REVERB_APP_KEY" "$VITE_REVERB_HOST" "$VITE_REVERB_PORT" "$VITE_REVERB_SCHEME" "$VITE_GO2RTC_URL" "$VITE_ERROR_REPORTING_URL" "$VITE_SENTRY_ENABLED" "$VITE_SENTRY_DSN" "$VITE_SENTRY_TRACES_SAMPLE_RATE" "$VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE" "$VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE" "$VITE_SENTRY_RELEASE" "$VITE_APP_ENV" "$VITE_ENABLE_QUERY_DEVTOOLS" "$SENTRY_AUTH_TOKEN" "$SENTRY_ORG" "$SENTRY_PROJECT" "$SENTRY_URL" \
    > .env.production

RUN npm run build:deploy

FROM nginx:1.27-alpine AS production

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://127.0.0.1/ || exit 1

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
