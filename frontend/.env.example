# URL pública do frontend (usada no manifest para o ícone abrir como app, não no navegador)
VITE_APP_URL=http://localhost:3000

# API URL (backend)
VITE_API_URL=http://127.0.0.1:8000/api/v1

# Token em cookie httpOnly (use true quando backend tiver SANCTUM_USE_TOKEN_COOKIE=true; exige mesma origem/CORS com credentials)
VITE_SANCTUM_USE_COOKIE=false

# WebSocket (Laravel Reverb)
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=seu-dominio.com.br
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# --- Sentry (Error Tracking) ---
VITE_SENTRY_ENABLED=true
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
VITE_SENTRY_RELEASE=1.0.0
VITE_APP_ENV=local
VITE_ENABLE_QUERY_DEVTOOLS=false
VITE_INMETRO_AUTO_SYNC=true

# Build-time Sentry upload (sourcemaps / release)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=https://sentry.io/

# URL para reportar erros de frontend (opcional — ex: Sentry, LogRocket)
VITE_ERROR_REPORTING_URL=
