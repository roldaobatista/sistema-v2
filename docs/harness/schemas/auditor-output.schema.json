{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kalibrium.local/schemas/auditor-output.schema.json",
  "title": "Autonomous Harness Auditor Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "layer",
    "cycle",
    "audit_mode",
    "auditor",
    "status",
    "generated_at",
    "summary",
    "agent_provenance",
    "scope",
    "provenance",
    "audit_limitations",
    "findings",
    "harness_errors"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string" },
    "layer": { "type": "integer", "minimum": 0, "maximum": 7 },
    "cycle": { "type": "integer", "minimum": 1 },
    "audit_mode": { "enum": ["full", "targeted", "verification_only"] },
    "auditor": {
      "enum": ["architecture-dependencies", "security-tenant", "code-quality", "tests-verification", "ops-provenance"]
    },
    "status": { "enum": ["approved", "issues_found", "blocked"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "agent_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "agent_role",
        "context_mode",
        "conversation_isolated",
        "orchestrator_generated",
        "prompt_summary"
      ],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "agent_role": { "enum": ["auditor-readonly"] },
        "context_mode": { "enum": ["clean"] },
        "conversation_isolated": { "const": true },
        "orchestrator_generated": { "const": false },
        "prompt_summary": { "type": "string", "minLength": 1 },
        "context_fingerprint": { "type": ["string", "null"] },
        "input_bundle_hash": { "type": ["string", "null"] }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "readonly", "canonical_sources"],
      "properties": {
        "allowed_paths": { "type": "array", "items": { "type": "string" } },
        "readonly": { "const": true },
        "canonical_sources": { "type": "array", "items": { "type": "string" } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_commit", "head_commit", "working_tree_state"],
      "properties": {
        "base_commit": { "type": ["string", "null"] },
        "head_commit": { "type": ["string", "null"] },
        "working_tree_state": { "enum": ["clean", "dirty", "unknown"] }
      }
    },
    "audit_limitations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["not_inspected", "assumptions", "required_verifications_not_executed"],
      "properties": {
        "not_inspected": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "required_verifications_not_executed": { "type": "array", "items": { "type": "string" } }
      }
    },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "harness_errors": { "type": "array", "items": { "$ref": "#/$defs/harness_error" } }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "root_cause_key",
        "title",
        "severity",
        "blocking",
        "block_type",
        "files",
        "evidence",
        "canonical_criterion",
        "recommended_verifications",
        "confidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "root_cause_key": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "blocking": { "type": "boolean" },
        "block_type": {
          "enum": [
            "blocked_environment",
            "blocked_missing_context",
            "blocked_policy",
            "blocked_code",
            "blocked_conflict"
          ]
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "line"],
            "properties": {
              "path": { "type": "string" },
              "line": { "type": ["integer", "null"], "minimum": 1 }
            }
          }
        },
        "evidence": { "type": "string" },
        "canonical_criterion": { "type": ["string", "null"] },
        "recommended_verifications": { "type": "array", "items": { "type": "string" } },
        "confidence": { "enum": ["low", "medium", "high"] }
      }
    },
    "harness_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": {
          "enum": [
            "harness_state_corruption",
            "harness_output_invalid",
            "harness_incomplete_run",
            "harness_provenance_mismatch",
            "harness_command_log_mismatch"
          ]
        },
        "message": { "type": "string" }
      }
    }
  }
}
